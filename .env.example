# Copy this file to .env and fill in the values
POSTGRES_USER=cheapflights
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cheapflights
SECRET_KEY=change-me-in-production

# URL the frontend is reachable at — used in password-reset emails
FRONTEND_URL=http://localhost:5173

# Set to true when running behind HTTPS in production (adds Secure flag to auth cookie)
COOKIE_SECURE=false

# SMTP settings for sending password-reset emails.
# Defaults point to the local Mailpit container — view caught mail at http://localhost:8025.
# Override these to use a real provider (Gmail, SendGrid, Mailgun, etc.) in production.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@elcheeapo.com
