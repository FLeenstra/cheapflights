# Copy this file to .env and fill in the values
POSTGRES_USER=cheapflights
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cheapflights

# Required — JWT signing key. Use a long random string (e.g. openssl rand -hex 32).
# The app will refuse to start if this is missing or still set to the example value.
SECRET_KEY=change-me-in-production

# Required — password for the seeded admin account (email set via ADMIN_EMAIL).
# Change this before first deployment. The app will refuse to start if this is missing.
ADMIN_PASSWORD=Admin1234!

# URL the frontend is reachable at — used in password-reset emails
FRONTEND_URL=http://localhost:5173

# Set to true when running behind HTTPS in production (adds Secure flag to auth cookie)
COOKIE_SECURE=false

# SMTP settings for sending password-reset emails.
# Defaults point to the local Mailpit container — view caught mail at http://localhost:8025.
# Override these to use a real provider (Gmail, SendGrid, Mailgun, etc.) in production.
SMTP_HOST=mailpit
SMTP_PORT=1025
# Set to true in production to enforce STARTTLS. Leave false for local Mailpit dev.
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@elcheeapo.com
