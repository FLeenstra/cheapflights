# Copy this file to .env and fill in the values
POSTGRES_USER=cheapflights
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cheapflights
SECRET_KEY=change-me-in-production

# URL the frontend is reachable at — used in password-reset emails
FRONTEND_URL=http://localhost:5173

# SMTP settings for sending password-reset emails.
# Leave SMTP_HOST empty to skip sending and print the reset link to stdout instead (useful in dev).
# Works with any STARTTLS-capable SMTP provider (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
